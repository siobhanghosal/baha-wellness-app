APP_NAME="BAHA Wellness RAG"
ENVIRONMENT=local
DATABASE_URL=postgresql+asyncpg://baha:baha@postgres:5432/baha_rag
AUTH_JWKS_URL=
AUTH_JWT_SECRET=
AUTH_ISSUER=
AUTH_AUDIENCE=
ALLOW_DEV_IDENTITY_HEADERS=true
OBJECT_STORAGE_PROVIDER=local
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_PUBLIC_BASE_URL=
OBJECT_STORAGE_PREFIX=raw
ALLOWED_CORS_ORIGINS=http://localhost:3000,http://localhost:8080
RETRIEVAL_TOP_K=8
MIN_CONFIDENCE=0.35
BUDDY_GENERATION_BACKEND=ollama
BUDDY_CHAT_MODE=grounded
BUDDY_OLLAMA_BASE_URL=http://localhost:11434
BUDDY_OLLAMA_MODEL=qwen3:4b
BUDDY_OLLAMA_TIMEOUT_SECONDS=60
BUDDY_OLLAMA_KEEP_ALIVE=10m
BUDDY_OLLAMA_THINK=false
BUDDY_HISTORY_WINDOW=6
BUDDY_MIN_RETRIEVAL_CONFIDENCE=0.45
BUDDY_DEMO_PERMISSIVE_MODE=false
STORAGE_ROOT=storage/raw
CRAWL_CONCURRENT_REQUESTS=8
CRAWL_DOWNLOAD_DELAY_SECONDS=1.0
CRAWL_DEPTH_LIMIT=3
EMBEDDING_BACKEND=hash
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIMENSIONS=1024
EMBEDDING_CHUNK_TOKENS=1024
EMBEDDING_CHUNK_OVERLAP_TOKENS=150
EMBEDDING_BATCH_SIZE=8
EMBEDDING_AUTO_INDEX=false
