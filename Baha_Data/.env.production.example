APP_NAME="BAHA Wellness RAG"
ENVIRONMENT=production

# Managed Postgres with pgvector enabled
DATABASE_URL=postgresql+asyncpg://<db_user>:<db_password>@<db_host>:5432/<db_name>

# Preferred auth path for Supabase-hosted JWT verification
AUTH_JWKS_URL=https://<supabase-project-ref>.supabase.co/auth/v1/.well-known/jwks.json
AUTH_JWT_SECRET=
AUTH_ISSUER=https://<supabase-project-ref>.supabase.co/auth/v1
AUTH_AUDIENCE=authenticated
ALLOW_DEV_IDENTITY_HEADERS=false

# Object storage
OBJECT_STORAGE_PROVIDER=supabase
OBJECT_STORAGE_BUCKET=baha-assets
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_ENDPOINT=https://<supabase-project-ref>.supabase.co/storage/v1
OBJECT_STORAGE_PUBLIC_BASE_URL=https://<supabase-project-ref>.supabase.co/storage/v1/object/public
OBJECT_STORAGE_PREFIX=raw

# API runtime
ALLOWED_CORS_ORIGINS=https://student.baha.app,https://parent.baha.app,https://teacher.baha.app,https://dashboard.baha.app
STORAGE_ROOT=storage/raw

# Retrieval and embeddings
RETRIEVAL_TOP_K=8
MIN_CONFIDENCE=0.35
EMBEDDING_BACKEND=bge
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIMENSIONS=1024
EMBEDDING_CHUNK_TOKENS=1024
EMBEDDING_CHUNK_OVERLAP_TOKENS=150
EMBEDDING_BATCH_SIZE=8
EMBEDDING_AUTO_INDEX=false

# Crawling
CRAWL_CONCURRENT_REQUESTS=8
CRAWL_DOWNLOAD_DELAY_SECONDS=1.0
CRAWL_DEPTH_LIMIT=3
