APP_NAME="BAHA Wellness Companion API"
APP_VERSION="0.1.0"
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
DOCS_URL=/docs
REDOC_URL=/redoc
OPENAPI_URL=/openapi.json
DATABASE_URL=postgresql+asyncpg://baha:baha@postgres:5432/baha_companion
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=1800
TRUSTED_HOSTS=localhost,127.0.0.1
ALLOWED_CORS_ORIGINS=http://localhost:3000,http://localhost:8080
LOG_LEVEL=INFO
LOG_JSON=true
AUTH_SECRET_KEY=change-me-in-production
AUTH_ALGORITHM=HS256
AUTH_ISSUER=baha-companion
AUTH_AUDIENCE=baha-clients
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=14
REFRESH_TOKEN_IDLE_MINUTES=1440
PASSWORD_MIN_LENGTH=12
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
MAX_FAILED_LOGIN_ATTEMPTS=5
FAILED_LOGIN_WINDOW_MINUTES=15
LOGIN_LOCKOUT_MINUTES=15
REQUIRE_EMAIL_VERIFICATION_FOR_LOGIN=false
REFRESH_COOKIE_NAME=baha_refresh_token
CSRF_COOKIE_NAME=baha_csrf_token
COOKIE_PATH=/
SECURE_COOKIES=false
COOKIE_SAMESITE=lax
ENABLE_COOKIE_AUTH=true
AUTH_RATE_LIMIT_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
WRITE_RATE_LIMIT_ATTEMPTS=120
WRITE_RATE_LIMIT_WINDOW_SECONDS=60
EXPOSE_DEBUG_TOKENS=true
CSRF_HEADER_NAME=X-CSRF-Token
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
LLM_ACTIVE_MODEL_KEY=gpt_4o_mini
LLM_MODEL_CATALOG_JSON=
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.9
LLM_MAX_OUTPUT_TOKENS=1200
LLM_FREQUENCY_PENALTY=0.0
LLM_PRESENCE_PENALTY=0.0
LLM_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=0.25
LLM_STREAMING_ENABLED=true
LLM_MAX_CONTEXT_TOKENS=5000
LLM_CONTEXT_CANDIDATE_LIMIT=6
LLM_MAX_RECENT_MESSAGES=8
LLM_MIN_CONTEXT_SCORE=0.15
LLM_REQUIRE_CITATIONS=true
LLM_SSE_HEARTBEAT_SECONDS=15
