APP_NAME="BAHA Wellness RAG"
ENVIRONMENT=local
DATABASE_URL=postgresql+asyncpg://baha:baha@postgres:5432/baha_rag
ALLOWED_CORS_ORIGINS=http://localhost:3000,http://localhost:8080
RETRIEVAL_TOP_K=8
MIN_CONFIDENCE=0.35
STORAGE_ROOT=storage/raw
CRAWL_CONCURRENT_REQUESTS=8
CRAWL_DOWNLOAD_DELAY_SECONDS=1.0
CRAWL_DEPTH_LIMIT=3
EMBEDDING_BACKEND=bge
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIMENSIONS=1024
EMBEDDING_CHUNK_TOKENS=1024
EMBEDDING_CHUNK_OVERLAP_TOKENS=150
EMBEDDING_BATCH_SIZE=8
EMBEDDING_AUTO_INDEX=false
